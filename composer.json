{
    "name": "heartcore/studio-site",
    "description": "HeartCore Pilates Studio — Beograd. Server-rendered site on the Flight microframework.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "flightphp/core": "^3.12"
    },
    "autoload": {
        "psr-4": {
            "HeartCore\\": "app/src/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
